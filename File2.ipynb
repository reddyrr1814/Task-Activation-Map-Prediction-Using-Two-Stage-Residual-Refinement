# ═══════════════════════════════════════════════════════════
# FC Fingerprint + Ridge Regression
# Reproduces r = 0.7418 on RELATIONAL COPE1
# ═══════════════════════════════════════════════════════════

import os
import pickle
import numpy as np
from sklearn.linear_model import Ridge
from sklearn.model_selection import train_test_split
from tqdm import tqdm

# ── 0. Paths & Settings ───────────────────────────────────────────────────────
PATH_FMRI  = r'F:\fMRI_DATA\FMRI'
PATH_TASK  = r'E:\task_contrasts\RELATIONAL\RELATIONAL_COPE_1_mapped_data'
OUTPUT_DIR = r'E:\brain_gnn_outputs'
N_PARCELS  = 360
ALPHA      = 5.0
TEST_SIZE  = 0.2
SEED       = 42

# ── 1. Subject list ───────────────────────────────────────────────────────────
# filtered_array must already be defined — list of 336 subject IDs
# If not, load from folder:
# filtered_array = sorted(os.listdir(PATH_FMRI))

print(f"Subjects : {len(filtered_array)}")

# ── 2. Train/test split ───────────────────────────────────────────────────────
indices = list(range(len(filtered_array)))
tr_idx, te_idx = train_test_split(indices, test_size=TEST_SIZE, random_state=SEED)
print(f"Train    : {len(tr_idx)} | Test: {len(te_idx)}")

# ── 3. Compute & cache FC fingerprints ────────────────────────────────────────

def compute_fc_fingerprint(grayord_ts, parcel_ts):
    """
    Pearson correlation of each grayordinate with each parcel mean timeseries.
    grayord_ts : (n_g, 1200)
    parcel_ts  : (360, 1200)
    returns    : (n_g, 360)
    """
    g = grayord_ts - grayord_ts.mean(axis=1, keepdims=True)
    g = g / (np.linalg.norm(g, axis=1, keepdims=True) + 1e-8)
    p = parcel_ts  - parcel_ts.mean(axis=1,  keepdims=True)
    p = p / (np.linalg.norm(p, axis=1,  keepdims=True) + 1e-8)
    return (g @ p.T).astype(np.float32)   # (n_g, 360)


def get_parcel_mean_ts(subject_id):
    """Mean BOLD timeseries per parcel → (360, 1200)"""
    parcel_ts = []
    for p in range(1, N_PARCELS + 1):
        path = os.path.join(PATH_FMRI, subject_id, f'class_{p}.0.pkl')
        if os.path.exists(path):
            ts = np.array(pickle.load(open(path,'rb')), dtype=np.float32)
            parcel_ts.append(ts.mean(axis=0))
        else:
            parcel_ts.append(np.zeros(1200, dtype=np.float32))
    return np.stack(parcel_ts)   # (360, 1200)


def build_fingerprint_cache(subject_id, force=False):
    """Build and cache fingerprints for one subject."""
    out_dir = os.path.join(OUTPUT_DIR, "fingerprints", subject_id)
    os.makedirs(out_dir, exist_ok=True)

    # skip if already cached
    if not force:
        existing = [f for f in os.listdir(out_dir) if f.endswith('.npy')]
        if len(existing) == N_PARCELS:
            return

    parcel_ts = get_parcel_mean_ts(subject_id)   # (360, 1200)

    for p_idx in range(N_PARCELS):
        out_path = os.path.join(out_dir, f'class_{p_idx}.npy')
        if os.path.exists(out_path) and not force:
            continue
        ts_path = os.path.join(PATH_FMRI, subject_id, f'class_{p_idx+1}.0.pkl')
        if not os.path.exists(ts_path):
            continue
        ts = np.array(pickle.load(open(ts_path,'rb')), dtype=np.float32)
        fp = compute_fc_fingerprint(ts, parcel_ts)
        np.save(out_path, fp)


print("\nBuilding fingerprint cache (skips if already done)...")
for subj in tqdm(filtered_array, desc="Fingerprints"):
    build_fingerprint_cache(subj)
print("Cache ready ✓")

# ── 4. Load everything into RAM ───────────────────────────────────────────────
print("\nLoading fingerprints + task maps into RAM...")

all_fp   = {}   # {subj: list of 360 arrays (n_g, 360)}
all_task = {}   # {subj: list of 360 arrays (n_g,)}

for subj in tqdm(filtered_array, desc="Loading"):
    fp_list   = []
    task_list = []
    for p_idx in range(N_PARCELS):
        # fingerprint
        fp_path = os.path.join(OUTPUT_DIR, "fingerprints", subj, f'class_{p_idx}.npy')
        fp_list.append(np.load(fp_path).astype(np.float32) if os.path.exists(fp_path) else None)
        # task map
        task_path = os.path.join(PATH_TASK, subj, f'class_{p_idx}.0.pkl')
        if os.path.exists(task_path):
            task_list.append(np.array(pickle.load(open(task_path,'rb')), dtype=np.float32))
        else:
            task_list.append(None)
    all_fp[subj]   = fp_list
    all_task[subj] = task_list

print("Loaded ✓")

# ── 5. Ridge per grayordinate ─────────────────────────────────────────────────
import warnings
warnings.filterwarnings('ignore', category=UserWarning)

print("\nRunning Ridge regression...")
all_preds_mat   = []
all_actuals_mat = []

for p_idx in tqdm(range(N_PARCELS), desc="Ridge"):
    feats_all, task_all = [], []

    for subj in filtered_array:
        fp   = all_fp[subj][p_idx]
        task = all_task[subj][p_idx]
        if fp is None or task is None:
            feats_all.append(None)
            task_all.append(None)
            continue
        feats_all.append(fp)
        task_all.append(task)

    valid = [(f,t) for f,t in zip(feats_all,task_all) if f is not None]
    if len(valid) < 10:
        continue

    feats_arr = np.stack([v[0] for v in valid])   # (n_subj, n_g, 360)
    task_arr  = np.stack([v[1] for v in valid])   # (n_subj, n_g)
    n_subj    = feats_arr.shape[0]

    tr = [i for i in tr_idx if i < n_subj]
    te = [i for i in te_idx  if i < n_subj]

    for j in range(feats_arr.shape[1]):
        reg = Ridge(alpha=ALPHA)
        reg.fit(feats_arr[tr, j, :], task_arr[tr, j])
        pred = reg.predict(feats_arr[te, j, :])
        all_preds_mat.append(pred)
        all_actuals_mat.append(task_arr[te, j])

# ── 6. Evaluate ───────────────────────────────────────────────────────────────
gt    = np.stack(all_actuals_mat)   # (59412, n_test)
predi = np.stack(all_preds_mat)     # (59412, n_test)

r = [np.corrcoef(gt[:,i], predi[:,i])[0,1] for i in range(gt.shape[1])]

print(f"\n{'='*50}")
print(f"Mean Pearson r : {np.mean(r):.4f}")
print(f"Max            : {max(r):.4f}")
print(f"Min            : {min(r):.4f}")
print(f"{'='*50}")

# ── 7. Save ───────────────────────────────────────────────────────────────────
os.makedirs(OUTPUT_DIR, exist_ok=True)

with open(os.path.join(OUTPUT_DIR, 'actual__RELATIONAL_COPE1.pkl'), 'wb') as f:
    pickle.dump(gt, f)

with open(os.path.join(OUTPUT_DIR, 'predicted__Ridge_alpha5__parcel_fingerprint_360__RELATIONAL_COPE1.pkl'), 'wb') as f:
    pickle.dump(predi, f)

print("Saved ✓")
